# OpenBucket example configuration
#
# The CLI reads its process environment; it does not automatically load this
# file. Docker Compose reads .env for interpolation. NEXT_PUBLIC_* values are
# consumed when the dashboard bundle is built.

# --- Storage and node identity ------------------------------------------------

OPENBUCKET_STORAGE_ROOT=./openbucket-data
OPENBUCKET_NODE_NAME=my-openbucket
# Compatibility alias for OPENBUCKET_NODE_NAME:
# OPENBUCKET_NAME=my-openbucket

# --- Listener configuration ---------------------------------------------------

# OPENBUCKET_HOST is the shared fallback. Specific hosts take precedence.
# Keep loopback defaults unless a firewall/proxy protects the listeners.
OPENBUCKET_HOST=127.0.0.1
# OPENBUCKET_MANAGEMENT_HOST=127.0.0.1
# OPENBUCKET_S3_HOST=127.0.0.1
OPENBUCKET_MANAGEMENT_PORT=7272
OPENBUCKET_S3_PORT=8333

# --- Dashboard, advertised URLs, and CORS ------------------------------------

# OPENBUCKET_DASHBOARD_URL=http://localhost:3000
# The CLI serves the built dashboard at a local dashboard URL by default.
# Set false when a separate dashboard service owns port 3000 (as in Compose).
# OPENBUCKET_SERVE_DASHBOARD=true
# OPENBUCKET_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# A managed public URL changes advertised/share URLs and disables the automatic
# Quick Tunnel. Configure a real reverse proxy/named tunnel and TLS separately.
# OPENBUCKET_PUBLIC_BASE_URL=https://storage.openbucket.dev
# Compatibility alias for OPENBUCKET_PUBLIC_BASE_URL:
# OPENBUCKET_PUBLIC_URL=https://storage.openbucket.dev

# Account-connected serve defaults to an S3-only Quick Tunnel when no managed
# public URL is configured. Quick Tunnels are development/preview only. Set
# false (or use --no-tunnel) to disable the automatic tunnel.
# OPENBUCKET_TUNNEL=quick
# OPENBUCKET_CLOUDFLARED_PATH=cloudflared

# --- Management authentication -----------------------------------------------

# Replace this before using Docker Compose. For normal CLI use, leaving both
# token variables unset makes the CLI generate a random management token.
# Required for Compose/automation. Supply at least 32 random UTF-8 bytes.
OPENBUCKET_ADMIN_TOKEN=
# Compatibility alias for OPENBUCKET_ADMIN_TOKEN:
# OPENBUCKET_TOKEN=

# --- Process and CLI state ----------------------------------------------------

# OPENBUCKET_DETACH=false
# OPENBUCKET_OPEN_DASHBOARD=true
# Set false in persistent-log environments; create a workload key through the
# authenticated management API/dashboard instead.
# OPENBUCKET_SHOW_INITIAL_CREDENTIALS=true
# OPENBUCKET_HOME=~/.openbucket
# Compatibility alias for OPENBUCKET_HOME:
# OPENBUCKET_STATE_DIR=~/.openbucket
# Relative log paths resolve from the current working directory.
# OPENBUCKET_LOG_FILE=./openbucket-daemon.log
# Hosted account/control-plane origin used by login, node registration, heartbeat,
# usage reporting, and discovery. Override for a custom Vercel/domain deployment.
# OPENBUCKET_CONTROL_PLANE_URL=https://openbucket-eight.vercel.app
# Local-development escape hatch. Disables account requirements, registration,
# metering, discovery, and automatic tunneling; do not use as production mode.
# OPENBUCKET_OFFLINE=false
# Non-serve CLI commands can control a remote/explicit management endpoint.
# OPENBUCKET_MANAGEMENT_URL=http://127.0.0.1:7272
# OPENBUCKET_START_TIMEOUT_MS=15000
# Packaging/test-only version override:
# OPENBUCKET_VERSION=0.1.1

# --- Dashboard build ----------------------------------------------------------

# Compose derives these from the management/dashboard port variables below.
# Set them only when the browser-facing origins differ.
# NEXT_PUBLIC_OPENBUCKET_API_URL=http://127.0.0.1:7272
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_DOCS_URL=https://openbucket.dev/docs

# Vercel uses the same three non-secret NEXT_PUBLIC_* build values. When
# NEXT_PUBLIC_APP_URL is omitted, the Vercel build derives it from
# VERCEL_PROJECT_PRODUCTION_URL. Never place management/S3 credentials in a
# NEXT_PUBLIC_* value because it is compiled into browser-visible JavaScript.
# NEXT_PUBLIC_OPENBUCKET_API_URL=https://management-tunnel.example
# NEXT_PUBLIC_APP_URL=https://openbucket-eight.vercel.app
# NEXT_PUBLIC_DOCS_URL=https://openbucket-eight.vercel.app/docs

# Example branded deployment values (replace the local values above only after
# DNS, TLS, and routing exist):
# NEXT_PUBLIC_OPENBUCKET_API_URL=https://api.openbucket.dev
# NEXT_PUBLIC_APP_URL=https://app.openbucket.dev
# NEXT_PUBLIC_DOCS_URL=https://openbucket.dev/docs
# OPENBUCKET_DASHBOARD_URL=https://app.openbucket.dev
# OPENBUCKET_PUBLIC_BASE_URL=https://storage.openbucket.dev

# --- Hosted account and control plane (server only) --------------------------

# These values are read only by Vercel Functions. They are not required by the
# explicit offline local dashboard and must never use NEXT_PUBLIC_ or VITE_.
# Store real credentials in Vercel environment settings, never in this file.
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
MONGODB_DATABASE=openbucket_web
# MongoDB stores account/session records plus node registrations, hashed node
# credentials, latest heartbeat/storage summaries, and aggregate usage events.
# It never stores object bytes, raw node tokens, management tokens, or S3 keys.
# Future discovery hostnames default to s3.<node>.openbucket.dev. Changing this
# value advertises a future hostname; it does not provision DNS or a data route.
# OPENBUCKET_NODE_DOMAIN=openbucket.dev
# Generate at least 32 random bytes; changing it invalidates hosted sessions.
# OPENBUCKET_AUTH_SECRET=
# Required only while signup is enabled. The first successful owner creation
# atomically consumes this high-entropy token in MongoDB, including across old
# immutable deployment URLs. Generate a different value from the auth secret.
# OPENBUCKET_SIGNUP_TOKEN=
# Keep false except during an intentional one-time owner bootstrap.
# Add --manage-vercel only when the helper should open and close the short-lived
# production window automatically. It is disabled by default.
OPENBUCKET_ALLOW_SIGNUP=false

# --- Docker Compose-only interpolation ---------------------------------------

# A declared named volume is the default. Set a host path for a bind mount,
# such as ./openbucket-data or C:/OpenBucket/data.
OPENBUCKET_STORAGE_MOUNT=openbucket-data
OPENBUCKET_DOCKER_BIND_HOST=127.0.0.1
OPENBUCKET_DASHBOARD_PORT=3000
# The standard Compose image does not contain cloudflared. Keep automatic Quick
# Tunnel disabled; set a managed OPENBUCKET_PUBLIC_BASE_URL when routing exists.
OPENBUCKET_TUNNEL=false

# --- S3 client examples only --------------------------------------------------

# These are read by examples, not by the daemon itself. Never commit secrets.
# OPENBUCKET_ACCESS_KEY=
# OPENBUCKET_SECRET_KEY=
# OPENBUCKET_S3_ENDPOINT=http://127.0.0.1:8333
# OPENBUCKET_REGION=auto

# --- Management/installer helper scripts only --------------------------------

# OPENBUCKET_API=http://127.0.0.1:7272
# OPENBUCKET_DOWNLOAD_PATH=./downloaded-object.bin
# OPENBUCKET_NPM_PACKAGE=openbucket
# OPENBUCKET_INSTALL_VERSION=latest
# OPENBUCKET_NPM_PREFIX=
