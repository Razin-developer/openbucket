# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.tmp/
/tmp*/
/.openbucket-data/

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/vercel-dist/
/.wrangler/
/outputs/
/work/
*.tsbuildinfo

# Python build/test environments
**/__pycache__/
*.py[cod]
/.venv/
/python/.venv/
/python/.release-venv/
/python/.pytest_cache/
/python/.mypy_cache/
/python/.ruff_cache/
**/.tox/
**/.coverage
/python/build/
/python/dist/
**/*.egg-info/
coverage.xml

# release artifacts
/.release/
/openbucket-*.tgz
